    "No account. No cloud. No tracking." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لا حساب. لا سحابة. لا تتبع."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Žádný účet. Žádný cloud. Žádné sledování."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen konto. Ingen sky. Ingen sporing."
          }
        },
