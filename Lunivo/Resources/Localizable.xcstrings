          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resten av dashbordet venter allerede nedenfor dette øyeblikket."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De rest van het dashboard wacht al onder dit moment."
          }
        },
