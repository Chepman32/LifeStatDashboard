    "Lunivo" : {

    },
    "Lunivo keeps everything on your device. No account. No cloud. No tracking. Just your timeline, rendered at unreasonable scale." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتفظ Lunivo بكل شيء على جهازك. لا حساب. لا سحابة. لا تتبع. فقط جدولك الزمني، مُقدَّم بمقياس لا يُصدَّق."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo uchovává vše ve vašem zařízení. Žádný účet. Žádný cloud. Žádné sledování. Jen váš časový přehled v neuvěřitelném měřítku."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo holder alt på din enhed. Ingen konto. Ingen sky. Ingen sporing. Bare din tidslinje, gengivet i ubeskrivelig skala."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo bewahrt alles auf deinem Gerät. Kein Konto. Keine Cloud. Kein Tracking. Nur deine Timeline, in unvorstellbarer Größenordnung."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το Lunivo κρατά τα πάντα στη συσκευή σου. Χωρίς λογαριασμό. Χωρίς cloud. Χωρίς παρακολούθηση. Μόνο το χρονοδιάγραμμά σου, σε απίστευτη κλίμακα."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo guarda todo en tu dispositivo. Sin cuenta. Sin nube. Sin rastreo. Solo tu línea de tiempo, a una escala increíble."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo pitää kaiken laitteellasi. Ei tiliä. Ei pilveä. Ei seurantaa. Vain aikajanasi, uskomattomassa mittakaavassa."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Iniiingatan ng Lunivo ang lahat sa iyong device. Walang account. Walang cloud. Walang tracking. Ang iyong timeline lamang, sa hindi kapani-paniwalang sukat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo conserve tout sur votre appareil. Aucun compte. Aucun cloud. Aucun suivi. Juste votre chronologie, à une échelle incroyable."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo שומר הכל במכשיר שלך. ללא חשבון. ללא ענן. ללא מעקב. רק ציר הזמן שלך, בקנה מידה בלתי נתפס."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo सब कुछ आपके डिवाइस पर रखता है। कोई खाता नहीं। कोई क्लाउड नहीं। कोई ट्रैकिंग नहीं। बस आपकी टाइमलाइन, अविश्वसनीय पैमाने पर।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A Lunivo mindent az eszközödön tárol. Nincs fiók. Nincs felhő. Nincs nyomkövetés. Csak az idővonaladFeltéve hihetetlenül nagy léptékben."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo menyimpan segalanya di perangkatmu. Tidak ada akun. Tidak ada cloud. Tidak ada pelacakan. Hanya linimasa hidupmu, dalam skala yang luar biasa."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo conserva tutto sul tuo dispositivo. Nessun account. Nessun cloud. Nessun tracciamento. Solo la tua linea del tempo, a una scala straordinaria."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivoはすべてをあなたのデバイスに保存します。アカウント不要。クラウド不要。追跡なし。ただあなたのタイムラインを、驚異的なスケールで。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo는 모든 것을 기기에 저장합니다. 계정 없음. 클라우드 없음. 추적 없음. 오직 당신의 타임라인만, 놀라운 규모로."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo menyimpan semua di peranti anda. Tiada akaun. Tiada awan. Tiada penjejakan. Hanya garis masa anda, dalam skala yang luar biasa."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo holder alt på enheten din. Ingen konto. Ingen sky. Ingen sporing. Bare tidslinjen din, i en utrolig skala."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo bewaart alles op je apparaat. Geen account. Geen cloud. Geen tracking. Alleen jouw tijdlijn, op onvoorstelbare schaal."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo przechowuje wszystko na twoim urządzeniu. Bez konta. Bez chmury. Bez śledzenia. Tylko twoja oś czasu w niewyobrażalnej skali."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Lunivo mantém tudo no seu dispositivo. Sem conta. Sem nuvem. Sem rastreamento. Apenas sua linha do tempo, em escala inacreditável."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo păstrează totul pe dispozitivul tău. Fără cont. Fără cloud. Fără urmărire. Doar cronologia ta, la o scară incredibilă."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo хранит всё на вашем устройстве. Нет аккаунта. Нет облака. Нет слежки. Только ваша временная шкала в невероятном масштабе."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo håller allt på din enhet. Inget konto. Inget moln. Ingen spårning. Bara din tidslinje, i en otrolig skala."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo เก็บทุกอย่างไว้ในอุปกรณ์ของคุณ ไม่มีบัญชี ไม่มีคลาวด์ ไม่มีการติดตาม แค่ไทม์ไลน์ของคุณในระดับที่น่าทึ่ง"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo her şeyi cihazında saklar. Hesap yok. Bulut yok. Takip yok. Sadece inanılmaz bir ölçekte zaman çizelgen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo зберігає все на вашому пристрої. Без облікового запису. Без хмари. Без відстеження. Лише ваша хронологія у неймовірному масштабі."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo lưu mọi thứ trên thiết bị của bạn. Không tài khoản. Không đám mây. Không theo dõi. Chỉ dòng thời gian của bạn, ở quy mô đáng kinh ngạc."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lunivo 将一切保存在您的设备上。无需账号。无需云端。无追踪。只有您的时间线，以惊人的规模呈现。"
          }
        }
      }
    },
