    "The rest of the dashboard is already waiting below this moment." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بقية لوحة المعلومات تنتظرك بالفعل أسفل هذه اللحظة."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zbytek přehledu již čeká pod tímto okamžikem."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Resten af dashboardet venter allerede nedenfor dette øjeblik."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Rest des Dashboards wartet bereits unterhalb dieses Moments."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το υπόλοιπο ταμπλό σε περιμένει ήδη κάτω από αυτή τη στιγμή."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El resto del panel ya espera debajo de este momento."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Loput kojelaudasta odottavat jo tämän hetken alla."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ang natitirang dashboard ay naghihintay na sa ibaba ng sandaling ito."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le reste du tableau de bord vous attend déjà sous ce moment."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "שאר הלוח כבר מחכה מתחת לרגע הזה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "डैशबोर्ड का बाकी हिस्सा इस पल के नीचे पहले से ही प्रतीक्षा कर रहा है।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Az irányítópult többi része már vár alatta ebben a pillanatban."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sisa dasbor sudah menunggu di bawah momen ini."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il resto della dashboard ti aspetta già sotto questo momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ダッシュボードの続きはすでにこの瞬間の下で待っています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "대시보드의 나머지는 이 순간 아래에서 이미 기다리고 있습니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
