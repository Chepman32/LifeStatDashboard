    "All calculations happen on this device and are labeled by derivation type." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "جميع الحسابات تتم على هذا الجهاز ومصنّفة حسب نوع الاشتقاق."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veškeré výpočty probíhají na tomto zařízení a jsou označeny typem odvození."
          }
        },
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle beregninger sker på denne enhed og er mærket med afledningstype."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Berechnungen finden auf diesem Gerät statt und sind nach Ableitungstyp gekennzeichnet."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Όλοι οι υπολογισμοί γίνονται σε αυτή τη συσκευή και επισημαίνονται κατά τύπο παραγωγής."
          }
        },
        "es-MX" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los cálculos ocurren en este dispositivo y están etiquetados por tipo de derivación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaikki laskelmat tapahtuvat tällä laitteella ja on merkitty johdannaistyypin mukaan."
          }
        },
        "fil" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lahat ng kalkulasyon ay nangyayari sa device na ito at may label ayon sa uri ng pagkuha."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tous les calculs s'effectuent sur cet appareil et sont étiquetés par type de dérivation."
          }
        },
        "he" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "כל החישובים מתבצעים במכשיר זה ומסומנים לפי סוג הגזירה."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सभी गणनाएं इस डिवाइस पर होती हैं और व्युत्पत्ति प्रकार द्वारा लेबल की जाती हैं।"
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Minden számítás ezen az eszközön történik, és levezetési típus szerint van jelölve."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semua perhitungan terjadi di perangkat ini dan diberi label berdasarkan jenis derivasi."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti i calcoli avvengono su questo dispositivo e sono etichettati per tipo di derivazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべての計算はこのデバイス上で行われ、導出タイプでラベル付けされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 계산은 이 기기에서 이루어지며 도출 유형으로 표시됩니다."
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Semua pengiraan berlaku pada peranti ini dan dilabel mengikut jenis terbitan."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle beregninger skjer på denne enheten og er merket med avledningstype."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle berekeningen vinden plaats op dit apparaat en zijn gelabeld op afleidingstype."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wszystkie obliczenia odbywają się na tym urządzeniu i są oznaczone typem wyprowadzenia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos os cálculos acontecem neste dispositivo e são rotulados por tipo de derivação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toate calculele au loc pe acest dispozitiv și sunt etichetate după tipul de derivare."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Все вычисления происходят на этом устройстве и помечены по типу вывода."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alla beräkningar sker på den här enheten och är märkta med härledningstyp."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "การคำนวณทั้งหมดเกิดขึ้นบนอุปกรณ์นี้และมีป้ายกำกับตามประเภทการอนุมาน"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tüm hesaplamalar bu cihazda gerçekleşir ve türetme türüne göre etiketlenir."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Усі обчислення відбуваються на цьому пристрої та позначені за типом виведення."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tất cả tính toán diễn ra trên thiết bị này và được gắn nhãn theo loại suy luận."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
