    "These numbers are deterministic and local only. No external services are involved." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هذه الأرقام حتمية ومحلية فقط. لا توجد خدمات خارجية متورطة."
